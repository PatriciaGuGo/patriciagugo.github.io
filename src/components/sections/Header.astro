---
import ThemeToggle from '@/components/items/ThemeToggle.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import LanguagePicker from '@/components/items/LanguagePicker.astro';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const base = `/${lang}/`;
const navItems = [
	{ title: t('nav.experience'), label: 'experience', url: `${base}#experience` },
	{ title: t('nav.education'), label: 'education', url: `${base}#education` },
	{ title: t('nav.projects'), label: 'projects', url: `${base}#projects` },
	{ title: t('nav.about'), label: 'about', url: `${base}#about` },
	{ title: t('nav.contact'), label: 'contact', url: `${base}#contact` },
];
---

<header class="fixed top-0 z-20 flex flex-col items-center w-full mx-auto mt-3 px-3">
	<nav
		id="header-nav"
		class="flex items-center gap-1 px-2 py-1.5 text-sm font-medium rounded-full
		border border-black/5 dark:border-white/10 bg-white/70 dark:bg-[#141a22]/70 backdrop-blur-md
		shadow-sm text-ink-soft dark:text-[#9aa5b4]"
	>
		<a
			href={`${base}#home`}
			aria-label="home"
			class="flex items-center gap-1.5 pl-1.5 pr-2 transition hover:text-accent dark:hover:text-accent-hot"
			title="Patricia Guillén"
		>
			<svg viewBox="0 0 64 64" class="w-6 h-6" aria-hidden="true">
				<rect x="4" y="4" width="56" height="56" rx="16" fill="none" class="stroke-accent dark:stroke-accent-hot" stroke-width="5"></rect>
				<text x="32" y="42" text-anchor="middle" class="fill-steel dark:fill-steel-light" font-family="ui-monospace, monospace" font-size="24" font-weight="700">PG</text>
			</svg>
			<span class="hidden sm:inline font-semibold text-ink dark:text-white">Patricia</span>
		</a>
		{
			navItems.map((link) => (
				<a
					class="relative hidden lg:block px-3 py-1.5 rounded-full transition hover:text-accent dark:hover:text-accent-hot"
					aria-label={link.label}
					href={link.url}
				>
					{link.title}
				</a>
			))
		}
		<a
			href={`${base}#contact`}
			class="hidden lg:inline-block ml-1 px-4 py-1.5 rounded-full font-semibold text-white bg-accent hover:brightness-110 transition whitespace-nowrap"
		>
			{t('nav.cta')}
		</a>
		<ThemeToggle />
		<LanguagePicker />

		<!-- Botón de menú (solo móvil) -->
		<button
			id="menu-btn"
			type="button"
			class="lg:hidden ml-1 grid place-items-center size-8 rounded-full hover:text-accent dark:hover:text-accent-hot transition"
			aria-label="Abrir menú"
			aria-expanded="false"
			aria-controls="mobile-menu"
		>
			<svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
				<line x1="4" y1="7" x2="20" y2="7"></line>
				<line x1="4" y1="12" x2="20" y2="12"></line>
				<line x1="4" y1="17" x2="20" y2="17"></line>
			</svg>
		</button>
	</nav>

	<!-- Menú desplegable (solo móvil) -->
	<div
		id="mobile-menu"
		class="lg:hidden hidden mt-2 w-[min(92vw,20rem)] af-card p-2 flex-col text-sm font-medium text-ink-soft dark:text-[#9aa5b4]"
	>
		{
			navItems.map((link) => (
				<a
					class="block px-3 py-2.5 rounded-lg hover:bg-accent/10 hover:text-accent dark:hover:text-accent-hot transition"
					href={link.url}
				>
					{link.title}
				</a>
			))
		}
		<a
			href={`${base}#contact`}
			class="block mt-1 px-3 py-2.5 rounded-lg text-center font-semibold text-white bg-accent hover:brightness-110 transition"
		>
			{t('nav.cta')}
		</a>
	</div>
</header>

<script>
	const initHeader = () => {
		const menuBtn = document.getElementById('menu-btn');
		if (!menuBtn || menuBtn.dataset.bound === '1') return; // guard: no re-inicializar el mismo DOM
		menuBtn.dataset.bound = '1';

		// --- Scroll-spy: resalta la sección visible y la recuerda para el idioma ---
		const sections = document.querySelectorAll('section');
		const navLinks = document.querySelectorAll('#header-nav a');

		const callback = (entries: IntersectionObserverEntry[]) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					document.documentElement.dataset.section = entry.target.id;
					navLinks.forEach((item) => {
						item.classList.toggle('text-accent', item.getAttribute('aria-label') === entry.target.id);
					});
				}
			});
		};

		const observer = new IntersectionObserver(callback, { root: null, rootMargin: '0px', threshold: 0.3 });
		sections.forEach((section) => observer.observe(section));

		document.onvisibilitychange = () => {
			if (document.visibilityState === 'hidden') observer.disconnect();
			else sections.forEach((section) => observer.observe(section));
		};

		// --- Menú móvil ---
		const btn = document.getElementById('menu-btn');
		const menu = document.getElementById('mobile-menu');
		const setOpen = (open: boolean) => {
			menu?.classList.toggle('hidden', !open);
			menu?.classList.toggle('flex', open);
			btn?.setAttribute('aria-expanded', String(open));
		};
		btn?.addEventListener('click', (e) => {
			e.stopPropagation();
			// Cerrar el menú de tema si estaba abierto — mutuamente excluyentes.
			document.getElementById('themes-menu')?.classList.remove('open');
			setOpen(menu?.classList.contains('hidden') ?? false);
		});
		menu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
		document.addEventListener('click', () => setOpen(false));
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape') setOpen(false);
		});
	};

	// Corre con view-transitions (astro:page-load) Y en carga directa (p. ej. 404,
	// donde astro:page-load puede no dispararse). El guard evita doble-init.
	document.addEventListener('astro:page-load', initHeader);
	if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initHeader);
	else initHeader();
</script>
