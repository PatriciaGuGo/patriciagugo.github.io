---
interface Props {
	href: string;
	primary?: boolean;
	class?: string;
}
const { href, primary = false, class: cls = '' } = Astro.props;
const external = href.startsWith('http');
const base = 'inline-flex items-center justify-center gap-2 px-4 py-2 rounded-full text-sm font-semibold transition';
const style = primary
	? 'text-white bg-accent hover:brightness-110'
	: 'af-card text-ink dark:text-white hover:border-accent/40 hover:text-accent dark:hover:text-accent-hot';
---

<a
	href={href}
	target={external ? '_blank' : undefined}
	rel={external ? 'noopener noreferrer' : undefined}
	role="link"
	class:list={[base, style, cls]}
>
	<slot />
</a>
