---
/**
 * PostHog — analítica cookieless (opción A: persistence 'memory', sin banner).
 *
 * Plug & play: define las variables en un fichero `.env` (ver `.env.example`):
 *   PUBLIC_POSTHOG_KEY=phc_xxx            (tu Project API key)
 *   PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com   (o https://us.i.posthog.com)
 *
 * Sin key válida no renderiza nada (no carga PostHog, no envía nada).
 */
const key = import.meta.env.PUBLIC_POSTHOG_KEY ?? '';
const host = import.meta.env.PUBLIC_POSTHOG_HOST ?? 'https://eu.i.posthog.com';
const enabled = Boolean(key) && !key.includes('REPLACE');
---

{
	enabled && (
		<script define:vars={{ POSTHOG_KEY: key, POSTHOG_HOST: host }}>
			!(function (t, e) { var o, n, p, r; e.__SV || ((window.posthog = e), (e._i = []), (e.init = function (i, s, a) { function g(t, e) { var o = e.split('.'); 2 == o.length && ((t = t[o[0]]), (e = o[1])), (t[e] = function () { t.push([e].concat(Array.prototype.slice.call(arguments, 0))); }); } ((p = t.createElement('script')).type = 'text/javascript'), (p.crossOrigin = 'anonymous'), (p.async = !0), (p.src = s.api_host.replace('.i.posthog.com', '-assets.i.posthog.com') + '/static/array.js'), (r = t.getElementsByTagName('script')[0]).parentNode.insertBefore(p, r); var u = e; for (void 0 !== a ? (u = e[a] = []) : (a = 'posthog'), u.people = u.people || [], u.toString = function (t) { var e = 'posthog'; return 'posthog' !== a && (e += '.' + a), t || (e += ' (stub)'), e; }, u.people.toString = function () { return u.toString(1) + '.people (stub)'; }, o = 'init capture register register_once unregister getFeatureFlag isFeatureEnabled reloadFeatureFlags identify setPersonProperties group reset get_distinct_id onFeatureFlags set_config opt_in_capturing opt_out_capturing has_opted_out_capturing debug'.split(' '), n = 0; n < o.length; n++) g(u, o[n]); e._i.push([i, s, a]); }), (e.__SV = 1)); })(document, window.posthog || []);

			posthog.init(POSTHOG_KEY, {
				api_host: POSTHOG_HOST,
				persistence: 'memory',        // cookieless: no guarda nada en el dispositivo
				autocapture: true,            // clicks y elementos automáticamente
				capture_pageview: false,      // lo capturamos a mano (view transitions)
				disable_session_recording: true,
			});

			document.addEventListener('astro:page-load', function () {
				if (!(window.posthog && posthog.capture)) return;
				posthog.capture('$pageview');
			});
		</script>
	)
}
