# Analítica PostHog (cookieless). Copia este fichero a `.env` y pon tus valores.
# Sin PUBLIC_POSTHOG_KEY válida, PostHog NO se carga (nada de tracking).

# Project API key de PostHog (empieza por phc_)
PUBLIC_POSTHOG_KEY=phc_REPLACE_WITH_YOUR_KEY

# Host de PostHog según la región del proyecto:
#   EU (GDPR): https://eu.i.posthog.com   ·   US: https://us.i.posthog.com
PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
